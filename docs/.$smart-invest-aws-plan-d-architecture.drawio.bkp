        <mxCell id="gh" value="GitHub&#xa;(app-repo,&#xa;infra-repo)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#232F3E;strokeColor=#82B366;fontColor=#ffffff;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="280" y="170" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="gha" value="GitHub Actions (PR pipeline)&#xa;• mvn test (unit + JaCoCo)&#xa;• testcontainers integration tests&#xa;• SonarQube SAST + Checkmarx&#xa;• OWASP Dependency-Check&#xa;• Trivy / Grype SCA&#xa;• Lint / Format / SCA gate" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82B366;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="460" y="140" width="320" height="140" as="geometry" />
        </mxCell>
        <mxCell id="build" value="Build &amp; Package (main branch)&#xa;• Maven build JAR&#xa;• Docker buildx (multi-arch: amd64 + arm64)&#xa;• SBOM (syft) · attestation (SLSA)&#xa;• Push to ECR · Immutable tags&#xa;• Inspector scan on push (CVE)&#xa;• cosign sign-blob (keyless, OIDC)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82B366;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="820" y="140" width="340" height="140" as="geometry" />
        </mxCell>
        <mxCell id="ecr4" value="Amazon ECR&#xa;(private, image scan,&#xa;signed manifests,&#xa;lifecycle policy)" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#F58536;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.elastic_container_registry;" vertex="1" parent="1">
          <mxGeometry x="1200" y="170" width="64" height="64" as="geometry" />
        </mxCell>
        <mxCell id="update-manifest" value="Update infra-repo&#xa;kustomize image tag&#xa;→ git commit + PR" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82B366;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1300" y="170" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="argocd" value="ArgoCD (in-cluster)&#xa;&#xa;• Application CRDs · Sync-waves&#xa;• Automated sync (prune + selfHeal)&#xa;• RBAC (project + team)&#xa;• Dex / SSO integration" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;align=left;verticalAlign=top;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1540" y="140" width="300" height="140" as="geometry" />
        </mxCell>
        <mxCell id="rollouts" value="Argo Rollouts (progressive)&#xa;&#xa;Canary 10% → analysis (error rate, p95)&#xa;→ 50% → 100% · auto-rollback&#xa;AnalysisTemplate: Prometheus query&#xa;Blue/Green for schema-breaking" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;align=left;verticalAlign=top;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1880" y="140" width="380" height="140" as="geometry" />
        </mxCell>
        <mxCell id="promote-gate" value="Environment Promotion · manual approval gate for prod · dual-control change review" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="460" y="310" width="1800" height="40" as="geometry" />
        </mxCell>
        <mxCell id="dev-env" value="Dev Cluster&#xa;(sandbox)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82B366;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="540" y="370" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="stg-env" value="Staging Cluster&#xa;(smoke + perf tests)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82B366;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="820" y="370" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="prod-env" value="Production (us-east-1)&#xa;EKS + Aurora + Redis" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#B85450;align=center;verticalAlign=middle;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1120" y="370" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="dr-env" value="DR Warm (us-west-2)&#xa;pinned image tag" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#B85450;align=center;verticalAlign=middle;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1440" y="370" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="kyverno-note" value="Admission control (Kyverno):&#xa;Only ECR/* images + cosign-verified are admitted" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1740" y="370" width="480" height="60" as="geometry" />
        </mxCell>
        <mxCell id="iac" value="Infrastructure as Code&#xa;&#xa;• Terraform (modules: vpc, eks, aurora, cloudfront, waf)&#xa;• Helm (platform add-ons)&#xa;• Kustomize (app overlays: dev/staging/prod)&#xa;• Atlantis / TACOS on PR · tfsec · Checkov&#xa;• State: S3 + DynamoDB lock · KMS encrypted" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82B366;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="120" y="370" width="400" height="140" as="geometry" />
        </mxCell>
        <!-- Edges for CI/CD -->
        <mxCell id="ce1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#82B366;" edge="1" parent="1" source="dev" target="gh">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ce2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#82B366;" edge="1" parent="1" source="gh" target="gha">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ce3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#82B366;" edge="1" parent="1" source="gha" target="build">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ce4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#82B366;" edge="1" parent="1" source="build" target="ecr4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ce5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#82B366;" edge="1" parent="1" source="build" target="update-manifest">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ce6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#82B366;" edge="1" parent="1" source="update-manifest" target="argocd">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ce7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#82B366;" edge="1" parent="1" source="argocd" target="rollouts">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- SECURITY stack -->
        <mxCell id="sec-box" value="Security &amp; Compliance Plane — AWS Organizations-level" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#B85450;verticalAlign=top;align=left;fontSize=13;fontStyle=1;fontColor=#7A2E2A;" vertex="1" parent="1">
          <mxGeometry x="80" y="560" width="1140" height="520" as="geometry" />
        </mxCell>
        <mxCell id="sec-cloudtrail" value="AWS CloudTrail (Organization Trail)&#xa;• All accounts · All regions · Data events on S3 + Lambda&#xa;• Delivered to central S3 (Log Archive Acct)&#xa;• Object Lock (WORM, 7yr)&#xa;• CloudTrail Lake (SQL queries)&#xa;• CloudTrail Insights (anomaly detection)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#B85450;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="610" width="520" height="110" as="geometry" />
        </mxCell>
        <mxCell id="sec-config" value="AWS Config (multi-account aggregator)&#xa;• Conformance Pack: AWS-FinancialServicesBestPractices&#xa;• Auto-remediation: ec2-sg-attached · s3-ssl-only ·&#xa;  rds-storage-encrypted · eks-secrets-encrypted&#xa;• Continuous drift detection" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#B85450;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="640" y="610" width="560" height="110" as="geometry" />
        </mxCell>
        <mxCell id="sec-gd" value="Amazon GuardDuty&#xa;• EC2 · S3 · IAM · EKS Runtime · Malware Protection&#xa;• Cross-account delegated admin&#xa;• Findings → Security Hub → EventBridge → PagerDuty (P1)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#B85450;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="740" width="520" height="110" as="geometry" />
        </mxCell>
        <mxCell id="sec-hub" value="AWS Security Hub&#xa;• CIS AWS Foundations · CIS EKS · PCI-DSS · SOC2&#xa;• Aggregates GuardDuty · Config · Inspector · IAM AA · Macie&#xa;• Priority scoring · Automated remediation via SSM" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#B85450;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="640" y="740" width="560" height="110" as="geometry" />
        </mxCell>
        <mxCell id="sec-inspector" value="Amazon Inspector&#xa;• ECR image CVE scan on push&#xa;• EC2 / Lambda vulnerability scanning&#xa;• CVSS scoring · SBOM integration" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#B85450;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="870" width="360" height="100" as="geometry" />
        </mxCell>
        <mxCell id="sec-iam" value="IAM · IAM Identity Center (SSO)&#xa;• Least privilege (no wildcards)&#xa;• IAM Access Analyzer (cross-account + public access)&#xa;• Permission Boundary enforced&#xa;• AWS Verified Access (Zero Trust for admins)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#B85450;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="480" y="870" width="360" height="100" as="geometry" />
        </mxCell>
        <mxCell id="sec-macie" value="Amazon Macie (optional)&#xa;• Scans S3 for PII / PCI data&#xa;• Integrates with Security Hub" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#B85450;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="860" y="870" width="340" height="100" as="geometry" />
        </mxCell>
        <mxCell id="sec-compliance" value="Compliance Frameworks&#xa;• AWS Well-Architected (5 pillars)&#xa;• CIS Amazon EKS Benchmark · CIS AWS Foundations&#xa;• PCI-DSS v4.0 · SOC 2 Type II · NIST CSF · ISO 27001&#xa;• Artifact evidence pack auto-generated monthly" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="990" width="1100" height="80" as="geometry" />
        </mxCell>
        <!-- OBSERVABILITY -->
        <mxCell id="obs-box" value="Observability Plane — Metrics · Logs · Traces · Alerting" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#9673A6;verticalAlign=top;align=left;fontSize=13;fontStyle=1;fontColor=#3C1E5E;" vertex="1" parent="1">
          <mxGeometry x="1240" y="560" width="1080" height="520" as="geometry" />
        </mxCell>
        <mxCell id="obs-metrics" value="Metrics — Prometheus + Amazon Managed Prometheus&#xa;• node-exporter · kube-state-metrics · cAdvisor&#xa;• Spring Boot Actuator /actuator/prometheus&#xa;• Custom Business KPIs (orders/min, NAV freshness, MAU)&#xa;• remote_write to AMP · long-term storage&#xa;• Amazon Managed Grafana (SSO via Identity Center)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673A6;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1260" y="610" width="520" height="130" as="geometry" />
        </mxCell>
        <mxCell id="obs-logs" value="Logs — Fluent Bit → CloudWatch Logs / OpenSearch&#xa;• Structured JSON (traceId/spanId correlated)&#xa;• CloudWatch Log Insights queries&#xa;• 90d hot + S3 Glacier 7yr archive (compliance)&#xa;• Retention per log group (KMS encrypted)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673A6;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1800" y="610" width="500" height="130" as="geometry" />
        </mxCell>
        <mxCell id="obs-trace" value="Traces — AWS X-Ray / OpenTelemetry Collector&#xa;• OTel SDK in Spring Boot (auto-instrumentation)&#xa;• OTel Collector DaemonSet ships traces to X-Ray&#xa;• Service Map (API → service → DB → Redis)&#xa;• Trace sampling (tail-based for errors)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673A6;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1260" y="760" width="520" height="130" as="geometry" />
        </mxCell>
        <mxCell id="obs-synth" value="Synthetic &amp; RUM&#xa;• CloudWatch Synthetics canaries (login, place order)&#xa;• CloudWatch RUM (frontend JS perf / errors)&#xa;• Health checks from 3 regions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673A6;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1800" y="760" width="500" height="130" as="geometry" />
        </mxCell>
        <mxCell id="obs-alerts" value="Alerting — CloudWatch Alarms / Alertmanager → SNS → EventBridge" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;align=left;verticalAlign=top;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1260" y="910" width="1040" height="160" as="geometry" />
        </mxCell>
        <mxCell id="obs-p1" value="P1 (Critical, paging)&#xa;• API error rate &gt; 5% / 5min&#xa;• DB connection pool exhausted&#xa;• Pod CrashLoopBackOff&#xa;• GuardDuty HIGH finding&#xa;• Aurora failover event&#xa;→ PagerDuty (on-call rotation)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1280" y="950" width="320" height="110" as="geometry" />
        </mxCell>
        <mxCell id="obs-p2" value="P2 (Warning, async)&#xa;• CPU &gt; 80% for 10min&#xa;• Memory &gt; 85% for 10min&#xa;• Slow queries &gt; 1s&#xa;• Config drift detected&#xa;• Inspector MEDIUM finding&#xa;→ Slack #smart-invest-alerts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1620" y="950" width="320" height="110" as="geometry" />
        </mxCell>
        <mxCell id="obs-p3" value="P3 (Info, dashboard)&#xa;• Cost anomaly (Cost Anomaly Detection)&#xa;• Unusual traffic pattern&#xa;• Certificate expiry &lt; 30d&#xa;→ Email / Dashboard" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1960" y="950" width="320" height="110" as="geometry" />
        </mxCell>
        <!-- DR bottom -->
        <mxCell id="dr-box" value="Disaster Recovery &amp; Business Continuity" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EFF5FF;strokeColor=#6C8EBF;verticalAlign=top;align=left;fontSize=13;fontStyle=1;fontColor=#1F4E8A;" vertex="1" parent="1">
          <mxGeometry x="80" y="1100" width="2240" height="460" as="geometry" />
        </mxCell>
        <mxCell id="dr-rto-table" value="RTO / RPO Targets&#xa;&#xa;Pod failure     RTO &lt; 30s   RPO 0   (K8s reschedule)&#xa;Node failure   RTO &lt; 2m    RPO 0   (CA/Karpenter)&#xa;AZ failure      RTO &lt; 5m    RPO 0   (Multi-AZ spread + Aurora)&#xa;Region failure RTO &lt; 15m  RPO &lt; 5m (Aurora Global + R53 failover)&#xa;Data corruption RTO &lt; 30m RPO &lt; 5m (Aurora PITR)&#xa;Accidental delete RTO &lt; 1h RPO 24h (AWS Backup Vault Lock)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6C8EBF;align=left;verticalAlign=top;fontSize=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="100" y="1140" width="560" height="200" as="geometry" />
        </mxCell>
        <mxCell id="dr-backup2" value="AWS Backup — SmartInvestFinancialBackup Plan&#xa;&#xa;• Daily snapshot · retention 35 days&#xa;• Weekly snapshot · retention 1 year&#xa;• Monthly snapshot · retention 7 years (regulatory)&#xa;• Cross-region copy to us-west-2&#xa;• Backup Vault Lock (WORM) — prevents deletion&#xa;• KMS-encrypted (CMK per resource type)&#xa;• Covers: Aurora · EFS · DynamoDB · S3 (object-level)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6C8EBF;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="680" y="1140" width="560" height="200" as="geometry" />
        </mxCell>
        <mxCell id="dr-failover" value="Failover Orchestration&#xa;&#xa;1. Route 53 health check fails on primary ALB&#xa;2. DNS traffic shifts to us-west-2 ALB (latency policy)&#xa;3. `aws rds failover-global-cluster` promotes secondary&#xa;4. ArgoCD scales DR workloads (HPA min → target)&#xa;5. Validate: synthetic canaries + read/write smoke test&#xa;6. Confirm: comms · status page · post-incident review&#xa;&#xa;Chaos engineering: AWS FIS experiments monthly (AZ kill,&#xa;Pod kill, network latency injection)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6C8EBF;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1260" y="1140" width="560" height="200" as="geometry" />
        </mxCell>
        <mxCell id="dr-runbook" value="DR Runbook &amp; Governance&#xa;&#xa;• Quarterly DR drill (documented, dry-run then live)&#xa;• Runbooks in AWS SSM Documents (automation)&#xa;• Game-day exercises with dev teams&#xa;• RACI matrix for incident response (IC, ops, comms)&#xa;• Post-mortem culture — every P1 gets written review&#xa;• Evidence archived for auditor (7 years)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6C8EBF;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1840" y="1140" width="460" height="200" as="geometry" />
        </mxCell>
        <!-- key design decisions -->
        <mxCell id="kdd" value="Key Design Decisions (Solutions Architect Professional rationale)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E6;strokeColor=#D79B00;verticalAlign=top;align=left;fontSize=12;fontStyle=1;fontColor=#A65100;" vertex="1" parent="1">
          <mxGeometry x="80" y="1370" width="2240" height="180" as="geometry" />
        </mxCell>
        <mxCell id="kdd-content" value="• EKS over ECS Fargate — needed NetworkPolicy, PDB, Service Mesh optionality, fine-grained controls&#xa;• Aurora over RDS — faster failover (&lt; 30s), Global Database for cross-region, 6 copies across 3 AZs for durability&#xa;• Secrets Store CSI over K8s Secret — eliminate plaintext base64, Secrets Manager rotation, defense-in-depth&#xa;• ECR + cosign image signing — supply-chain security (SLSA Level 3 attestations), Kyverno admission enforcement&#xa;• ArgoCD GitOps over kubectl — declarative drift-detection, audit trail, pull-based security model&#xa;• AWS Load Balancer Controller (target-type ip) — skip iptables/kube-proxy hop, direct Pod targeting&#xa;• HPA + Karpenter — pod-level &amp; node-level elasticity; Karpenter over CA for faster, diverse-instance provisioning&#xa;• topologySpreadConstraints + PDB — hard guarantee of AZ-spread + availability during voluntary disruptions&#xa;• RDS Proxy — connection pooling (Spring HikariCP + Proxy), rotation-transparent, failover-aware for app&#xa;• IRSA per service — blast radius containment; no shared pod identity; token projection over long-lived creds&#xa;• Private API + VPC Endpoints — no Internet egress from data plane; reduced attack surface; consistent latency" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#D79B00;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="1410" width="2200" height="130" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
