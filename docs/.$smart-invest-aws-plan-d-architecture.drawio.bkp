          <mxGeometry x="910" y="1460" width="260" height="60" as="geometry" />
        </mxCell>
        <mxCell id="flow-csi" value="Secrets Store CSI Driver&#xa;(AWS provider, read-only mount)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673A6;align=center;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1220" y="1460" width="260" height="60" as="geometry" />
