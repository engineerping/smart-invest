        <mxCell id="ns-secrets" value="external-secrets / csi namespace&#xa;• Secrets Store CSI Driver (AWS provider)&#xa;• SecretProviderClass → Secrets Manager&#xa;• Auto sync to Kubernetes Secret objects (optional)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#D6B656;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1800" y="890" width="480" height="80" as="geometry" />
