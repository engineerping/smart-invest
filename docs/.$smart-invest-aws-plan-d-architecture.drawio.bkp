        <mxCell id="ns-chaos" value="chaos-engineering (optional)&#xa;• AWS Fault Injection Service (FIS) experiments&#xa;• LitmusChaos / Chaos Mesh — quarterly drills" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#D6B656;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
