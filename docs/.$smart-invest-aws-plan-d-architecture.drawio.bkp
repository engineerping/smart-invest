        <mxCell id="ns-monitor" value="monitoring namespace&#xa;• kube-prometheus-stack (Prometheus / Alertmanager / Grafana)&#xa;• node-exporter · kube-state-metrics&#xa;• remote_write → Amazon Managed Prometheus" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#D6B656;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
