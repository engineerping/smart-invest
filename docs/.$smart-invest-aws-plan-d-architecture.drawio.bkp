        <!-- Pod spec detail -->
        <mxCell id="pod-spec" value="Pod Security &amp; Scheduling Defaults (every workload)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;verticalAlign=top;align=left;fontSize=12;fontStyle=1;fontColor=#7A2E2A;" vertex="1" parent="1">
          <mxGeometry x="80" y="1090" width="1140" height="300" as="geometry" />
        </mxCell>
        <mxCell id="pod-sec" value="securityContext:&#xa;  runAsNonRoot: true · runAsUser: 1000 · fsGroup: 2000&#xa;  allowPrivilegeEscalation: false&#xa;  readOnlyRootFilesystem: true&#xa;  capabilities: drop [ALL]&#xa;  seccompProfile: RuntimeDefault&#xa;&#xa;Pod Security Admission: restricted&#xa;Image policy (Kyverno):&#xa;  imageReferences=ECR/*  attestors=cosign keyless (GitHub OIDC)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#B85450;align=left;verticalAlign=top;fontSize=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="100" y="1130" width="540" height="240" as="geometry" />
        </mxCell>
        <mxCell id="pod-sched" value="resources.requests/limits set (no unbounded)&#xa;&#xa;topologySpreadConstraints:&#xa;  - maxSkew: 1&#xa;    topologyKey: topology.kubernetes.io/zone&#xa;    whenUnsatisfiable: DoNotSchedule&#xa;&#xa;PodDisruptionBudget: minAvailable: 1 (2 for order)&#xa;readinessProbe · livenessProbe · startupProbe&#xa;RollingUpdate: maxSurge 1, maxUnavailable 0 (zero-downtime)&#xa;Graceful shutdown (preStop 30s + terminationGracePeriod 60s)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#B85450;align=left;verticalAlign=top;fontSize=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="660" y="1130" width="540" height="240" as="geometry" />
        </mxCell>
        <!-- HPA / scaling -->
        <mxCell id="scaling" value="Autoscaling Model" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;verticalAlign=top;align=left;fontSize=12;fontStyle=1;fontColor=#1F4E23;" vertex="1" parent="1">
          <mxGeometry x="1240" y="1090" width="1060" height="300" as="geometry" />
        </mxCell>
        <mxCell id="scaling-hpa" value="Pod-level — HPA v2&#xa;• CPU target 60% + Memory 70%&#xa;• scaleDown stabilizationWindow 300s&#xa;• scaleUp 0s delay, +100% per 15s&#xa;• custom metrics via Prometheus Adapter&#xa;  (e.g. req_per_pod_per_sec)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82B366;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1260" y="1130" width="330" height="240" as="geometry" />
        </mxCell>
        <mxCell id="scaling-node" value="Node-level — Karpenter / CA&#xa;• Karpenter NodePool: mix Spot/On-Demand&#xa;• Disruption budgets (nodePool.disruption)&#xa;• Consolidation: WhenUnderutilized&#xa;• Max expiration: 168h (1 week)&#xa;• Dedicated NodePool per tier" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82B366;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1610" y="1130" width="330" height="240" as="geometry" />
        </mxCell>
        <mxCell id="scaling-cost" value="Cost Guardrails&#xa;• Graviton (ARM) mixed in&#xa;• Compute Savings Plan (baseline)&#xa;• Spot for batch/async workloads&#xa;• AWS Budgets w/ multi-layer alerts&#xa;• Cost allocation tags:&#xa;  env, service, team, cost-center" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82B366;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1960" y="1130" width="320" height="240" as="geometry" />
        </mxCell>
        <!-- Secrets/IRSA flow bottom -->
        <mxCell id="secrets-flow" value="IRSA &amp; Secrets Flow" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;verticalAlign=top;align=left;fontSize=12;fontStyle=1;fontColor=#3C1E5E;" vertex="1" parent="1">
