        </mxCell>
        <mxCell id="flow-sa" value="K8s ServiceAccount&#xa;(per microservice)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673A6;align=center;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="120" y="1460" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="flow-oidc" value="EKS OIDC Provider&#xa;(JWT token projection)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673A6;align=center;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="370" y="1460" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="flow-sts" value="AWS STS AssumeRoleWithWebIdentity&#xa;(temporary credentials)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673A6;align=center;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="620" y="1460" width="240" height="60" as="geometry" />
