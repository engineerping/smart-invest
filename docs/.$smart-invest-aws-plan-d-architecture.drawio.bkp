        <mxCell id="ns-istio" value="cert-manager / ingress / kyverno namespace&#xa;• cert-manager (intra-cluster mTLS via ACM PCA or Let&#39;s Encrypt)&#xa;• AWS Load Balancer Controller (ALB Ingress, target-type ip)&#xa;• Kyverno / OPA Gatekeeper (image signature verification, PSA)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#D6B656;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
