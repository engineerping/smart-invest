        <mxCell id="oidc" value="OIDC Provider&#xa;(IRSA)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1100" y="160" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="cluster-addons-list" value="Managed Add-ons: VPC CNI · CoreDNS · kube-proxy · EBS CSI · Pod Identity Agent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1280" y="160" width="460" height="50" as="geometry" />
        </mxCell>
        <mxCell id="priv-api" value="Private API Endpoint&#xa;(no Internet)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1760" y="160" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="tagging" value="Fargate Profiles&#xa;(optional: system pods)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1980" y="160" width="320" height="50" as="geometry" />
        </mxCell>
        <!-- Node Groups row -->
        <mxCell id="ng-box" value="Managed Node Groups (EC2 Auto Scaling, Multi-AZ)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D79B00;verticalAlign=top;align=left;fontSize=12;fontStyle=1;fontColor=#A65100;" vertex="1" parent="1">
          <mxGeometry x="80" y="260" width="2240" height="180" as="geometry" />
        </mxCell>
        <mxCell id="ng-system" value="system-ng&#xa;&#xa;t3.medium · On-Demand&#xa;min 2 / max 4&#xa;&#xa;Taint: CriticalAddonsOnly=true&#xa;Runs: CoreDNS · Metrics Server ·&#xa;AWS LB Controller · cert-manager ·&#xa;Cluster Autoscaler · Karpenter" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="120" y="300" width="400" height="130" as="geometry" />
        </mxCell>
        <mxCell id="ng-app" value="app-ondemand-ng&#xa;&#xa;m5.large / m6g.large · On-Demand&#xa;min 2 / max 10 · per-AZ spread&#xa;&#xa;Runs: Tier-1 stateless services&#xa;(user-svc, order-svc, portfolio-svc,&#xa;plan-svc, fund-svc) · P1 workloads&#xa;Savings Plans committed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="540" y="300" width="400" height="130" as="geometry" />
        </mxCell>
        <mxCell id="ng-spot" value="app-spot-ng&#xa;&#xa;m5/m6g/c5.large·xlarge mix · Spot&#xa;min 0 / max 20&#xa;&#xa;Taint: spot=true:NoSchedule&#xa;Runs: batch jobs, NAV recompute,&#xa;report generation · cost-savings 60-80%&#xa;Node Termination Handler (interrupts)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="960" y="300" width="400" height="130" as="geometry" />
        </mxCell>
        <mxCell id="ng-gpu" value="(optional) gpu-ng&#xa;&#xa;g5.xlarge · On-Demand&#xa;min 0 / max 2&#xa;&#xa;Taint: nvidia.com/gpu=true&#xa;Runs: ML model scoring&#xa;(risk/fraud detection sidecar)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D79B00;align=left;verticalAlign=top;fontSize=10;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="1380" y="300" width="400" height="130" as="geometry" />
        </mxCell>
        <mxCell id="karpenter-box" value="Karpenter (node autoscaler)&#xa;&#xa;• Watches unschedulable pods&#xa;• Provisions ideal EC2 directly&#xa;• Consolidation: bin-packs &amp; drops under-utilized nodes&#xa;• Mix of Spot + On-Demand via NodePool&#xa;• Faster than Cluster Autoscaler (~30s)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;align=left;verticalAlign=top;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1800" y="300" width="500" height="130" as="geometry" />
        </mxCell>
        <!-- Namespace: smart-invest -->
        <mxCell id="ns-smart" value="Namespace: smart-invest    (RBAC: least privilege · ResourceQuota · LimitRange · NetworkPolicy default-deny)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EFF5FF;strokeColor=#6C8EBF;verticalAlign=top;align=left;fontSize=12;fontStyle=1;fontColor=#1F4E8A;" vertex="1" parent="1">
          <mxGeometry x="80" y="470" width="1680" height="600" as="geometry" />
        </mxCell>
        <!-- Services: columns -->
        <mxCell id="svc-user" value="user-service (Spring Boot)&#xa;&#xa;Deployment · replicas 2+ · HPA 2-20&#xa;Service: ClusterIP · port 8080&#xa;Image: ECR signed (cosign)&#xa;&#xa;• JWT issuance · Profile · KYC&#xa;• Risk tolerance (questionnaire)&#xa;&#xa;IRSA Role: user-sa-role&#xa;→ secrets: db-password, jwt-secret&#xa;&#xa;Actuator: /health · /prometheus&#xa;X-Ray · OpenTelemetry" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6C8EBF;verticalAlign=top;align=left;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="510" width="300" height="540" as="geometry" />
        </mxCell>
        <mxCell id="svc-fund" value="fund-service (Spring Boot)&#xa;&#xa;Deployment · replicas 2+ · HPA 2-20&#xa;Service: ClusterIP · port 8080&#xa;&#xa;• Fund catalog · NAV · Price history&#xa;• Asset allocation data&#xa;• Cached via Redis (fund:${code})&#xa;&#xa;IRSA Role: fund-sa-role&#xa;→ secrets: db-password, redis-auth&#xa;&#xa;Reads Aurora Reader (via RDS Proxy)&#xa;Async NAV refresh job → Spot NG" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6C8EBF;verticalAlign=top;align=left;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="410" y="510" width="300" height="540" as="geometry" />
        </mxCell>
        <mxCell id="svc-order" value="order-service (Spring Boot)&#xa;&#xa;Deployment · replicas 3+ · HPA 3-30&#xa;Service: ClusterIP · port 8080&#xa;&#xa;• Place/Cancel Order · Settlement&#xa;• PDB minAvailable: 2 (critical)&#xa;• Idempotency keys · Saga pattern&#xa;• Writes Aurora Writer&#xa;&#xa;IRSA Role: order-sa-role&#xa;→ secrets: db, jwt, ses-smtp&#xa;&#xa;Scheduled: OrderSettlementExecutor&#xa;Topology spread: required DoNotSchedule" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6C8EBF;verticalAlign=top;align=left;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="720" y="510" width="300" height="540" as="geometry" />
        </mxCell>
        <mxCell id="svc-portfolio" value="portfolio-service (Spring Boot)&#xa;&#xa;Deployment · replicas 2+ · HPA 2-20&#xa;Service: ClusterIP · port 8080&#xa;&#xa;• Holdings aggregation · Total mkt value&#xa;• Performance &amp; gain/loss calc&#xa;• Read-heavy → Aurora Reader&#xa;&#xa;IRSA Role: portfolio-sa-role&#xa;→ secrets: db-password (RO)&#xa;&#xa;readOnlyRootFilesystem: true&#xa;runAsNonRoot · drop ALL capabilities" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6C8EBF;verticalAlign=top;align=left;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1030" y="510" width="300" height="540" as="geometry" />
        </mxCell>
        <mxCell id="svc-plan" value="plan-service (Spring Boot)&#xa;&#xa;Deployment · replicas 2+ · HPA 2-10&#xa;Service: ClusterIP · port 8080&#xa;&#xa;• Investment Plan CRUD&#xa;• Scheduled monthly execution&#xa;  (K8s CronJob · 02:00 UTC)&#xa;• Triggers order-service (async)&#xa;&#xa;IRSA Role: plan-sa-role&#xa;→ secrets: db-password&#xa;&#xa;CronJob on Spot NG · concurrencyPolicy: Forbid" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6C8EBF;verticalAlign=top;align=left;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1340" y="510" width="300" height="540" as="geometry" />
        </mxCell>
        <!-- System namespaces column right -->
        <mxCell id="ns-sys" value="System Namespaces (GitOps-managed)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;verticalAlign=top;align=left;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1780" y="470" width="520" height="600" as="geometry" />
        </mxCell>
        <mxCell id="ns-argocd" value="argocd namespace&#xa;• ArgoCD Server / Repo Server / App Controller&#xa;• Argo Rollouts (Canary 10%/50%/100%)&#xa;• Pulls infra-repo → syncs to cluster" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#D6B656;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
