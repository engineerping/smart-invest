        <mxCell id="update-manifest" value="Update infra-repo&#10;kustomize image tag&#10;→ git commit + PR" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82B366;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
