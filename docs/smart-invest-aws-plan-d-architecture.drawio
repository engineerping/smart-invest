        <!-- Services: columns -->
        <mxCell id="svc-user" value="user-service (Spring Boot)&#10;&#10;Deployment · replicas 2+ · HPA 2-20&#10;Service: ClusterIP · port 8080&#10;Image: ECR signed (cosign)&#10;&#10;• JWT issuance · Profile · KYC&#10;• Risk tolerance (questionnaire)&#10;&#10;IRSA Role: user-sa-role&#10;→ secrets: db-password, jwt-secret&#10;&#10;Actuator: /health · /prometheus&#10;X-Ray · OpenTelemetry" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6C8EBF;verticalAlign=top;align=left;fontSize=10;" vertex="1" parent="1">
